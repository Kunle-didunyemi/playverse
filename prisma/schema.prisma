generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  username  String
  avatarUrl String?
  createdAt DateTime @default(now())
  scores    Score[]
}

model Game {
  id          String  @id
  title       String
  category    String
  multiplayer Boolean @default(false)
  scores      Score[]
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId, value(sort: Desc)])
  @@index([userId, gameId])
}
